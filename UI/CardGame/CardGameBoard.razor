@page "/"

<div style="display: flex; flex-direction: column; gap: 1rem;">

    <div style="display:flex; flex-direction: row; padding: 1rem; gap: 1rem;">
        @foreach (var card in Deck)
        {
            <GameCardView Card="card" OnCardSelected="OnCardSelected" IsSelected="SelectedCard == card" />
        }
    </div>

    <div>
        @if (SelectedCard is not null)
        {
            <div>Selected card: @SelectedCard.Name - @SelectedCard.Description</div>
        }
        else
        {
            <div>No card selected.</div>
        }
    </div>
</div>


@code {
    private GameCard? SelectedCard { get; set; }

    public List<GameCard> Deck { get; set; } = [];

    private void OnCardSelected(GameCard card)
    {
        if (SelectedCard == card)
        {
            SelectedCard = null;
        }
        else
        {
            SelectedCard = card;
        }
    }

    protected override void OnInitialized()
    {
        Deck.AddRange(
            new GameCard("Joker", "A wild card that can change the game.", "lightblue", "pink", "red"),
            new GameCard("Alakazam", "Alakawhat?", "orange", "darkgreen", "pink"),
            new GameCard("Ginny Weasley", "", "darkgrey", "green", "blue")
        );
    }
}
